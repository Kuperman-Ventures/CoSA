# JasonOS — local environment
# Copy to .env.local and fill in. Never commit real secrets.

# ---------- Supabase (shared with CoSA, but jasonos schema) ----------
# CoSA's existing Supabase project. Same URL + anon key.
NEXT_PUBLIC_SUPABASE_URL=https://vtxbdyqpmwtzijqlzvtc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only, never ship to the browser.
# Supabase Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Vercel AI Gateway ----------
# On Vercel deploys this is auto-injected via OIDC; only needed for local dev.
# Get one at https://vercel.com/dashboard → AI → API Keys
AI_GATEWAY_API_KEY=

# ---------- Integrations (wire as modules come online) ----------
HUBSPOT_ACCESS_TOKEN=
INSTANTLY_API_KEY=
# Stripe — Kuperman Advisors + Refactor Sprint revenue, invoicing
STRIPE_SECRET_KEY=
# Lemon Squeezy — gtmtools.io subscriptions, MRR, trial conversions, churn
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
TAPLIO_API_KEY=
LEADDELTA_API_KEY=
MERCURY_API_TOKEN=
VERCEL_ANALYTICS_TOKEN=
