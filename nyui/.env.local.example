# Copy the same values from your CoSA project's .env.local
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# IMPORTANT: RLS setup for work_searches and business_hours tables
# Run one of the following in your Supabase SQL editor:
#
# Option A — No RLS (simplest for a single-user personal tool):
#   (leave RLS disabled — the default after CREATE TABLE)
#
# Option B — Permissive policy if you have RLS enabled:
#   ALTER TABLE work_searches ENABLE ROW LEVEL SECURITY;
#   CREATE POLICY "allow_all" ON work_searches FOR ALL USING (true) WITH CHECK (true);
#   ALTER TABLE business_hours ENABLE ROW LEVEL SECURITY;
#   CREATE POLICY "allow_all" ON business_hours FOR ALL USING (true) WITH CHECK (true);
